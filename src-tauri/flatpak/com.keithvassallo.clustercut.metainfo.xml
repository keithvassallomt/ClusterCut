  <name>ClusterCut</name>
  <summary>Cross-platform Clipboard Sync</summary>
  <description>
    <p>
      ClusterCut is a seamless clipboard synchronization tool that works across Linux, macOS and Windows.
      It allows you to copy text on one device and paste it on another instantly, keeping your workflow uninterrupted.
    </p>
    <p>Features include:</p>
    <ul>
      <li>Real-time clipboard synchronization</li>
      <li>Secure peer-to-peer connection</li>
      <li>Clipboard history</li>
      <li>File transfer</li>
      <li>Automatic/Manual transfer mode</li>
      <li>Cross-platform support</li>
      <li>Minimal resource usage</li>
    </ul>
  </description>
  <developer id="com.keithvassallo">
    <name>Keith Vassallo</name>
  </developer>
  <launchable type="desktop-id">com.keithvassallo.clustercut.desktop</launchable>
